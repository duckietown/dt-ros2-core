  <version>1.0.0</version>
  <description>Lane filter for estimating lane pose from line segments.</description>

  <maintainer email="maintainer@example.com">Duckietown</maintainer>
  <license>GPLv3</license>

  <buildtool_depend>ament_python</buildtool_depend>

  <depend>rclpy</depend>
  <depend>duckietown_msgs</depend>
